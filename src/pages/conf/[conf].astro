---
const conferences = {
  ndss: {
    title: 'NDSS',
    name: 'Network and Distributed System Security Symposium',
    theme: '网络与分布式系统安全',
    official: 'https://www.ndss-symposium.org/',
    accent: '#1f6b5b'
  },
  sp: {
    title: 'IEEE S&P',
    name: 'IEEE Symposium on Security and Privacy',
    theme: '系统安全、隐私、安全基础研究',
    official: 'https://www.ieee-security.org/TC/SP-Index.html',
    accent: '#2e5f8a'
  },
  usenix: {
    title: 'USENIX Security',
    name: 'USENIX Security Symposium',
    theme: '系统、网络、软件和应用安全',
    official: 'https://www.usenix.org/conferences/byname/108',
    accent: '#b75237'
  },
  ccs: {
    title: 'ACM CCS',
    name: 'ACM Conference on Computer and Communications Security',
    theme: '计算机与通信安全综合顶会',
    official: 'https://www.sigsac.org/ccs.html',
    accent: '#7a5b2e'
  }
};

export function getStaticPaths() {
  return ['ndss', 'sp', 'usenix', 'ccs'].map((conf) => ({
    params: { conf }
  }));
}

const { conf } = Astro.params;
const meta = conferences[conf];
const now = new Date();
const currentYear = now.getFullYear();
const defaultYears = Array.from({ length: 5 }, (_, i) => currentYear - i);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content={`${meta.title} 论文库：按年份浏览、搜索和跟踪 AI 安全/网络安全顶会论文。`}
    />
    <title>{meta.title} — Security Papers</title>
    <style define:vars={{ confAccent: meta.accent }}>
      :root {
        color-scheme: light;
        --paper: #fbfbf8;
        --ink: #17211d;
        --muted: #64716b;
        --line: #d8ded8;
        --panel: #ffffff;
        --soft: #eef4ef;
        --accent: var(--confAccent);
        --shadow: 0 18px 55px rgba(23, 33, 29, 0.08);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background:
          radial-gradient(circle at 12% 10%, rgba(31, 107, 91, 0.10), transparent 28rem),
          radial-gradient(circle at 90% 0%, rgba(183, 82, 55, 0.10), transparent 22rem),
          var(--paper);
        color: var(--ink);
        font-family: Aptos, 'Gill Sans', 'PingFang SC', 'Noto Sans SC', sans-serif;
      }

      a {
        color: inherit;
      }

      .shell {
        width: min(1120px, calc(100% - 32px));
        margin: 0 auto;
      }

      .topbar {
        border-bottom: 1px solid var(--line);
        background: rgba(251, 251, 248, 0.92);
        backdrop-filter: blur(16px);
        position: sticky;
        top: 0;
        z-index: 10;
      }

      .nav {
        align-items: center;
        display: flex;
        gap: 14px;
        justify-content: space-between;
        min-height: 66px;
      }

      .brand {
        display: grid;
        font-family: Georgia, 'Times New Roman', serif;
        font-weight: 700;
        text-decoration: none;
      }

      .brand span {
        color: var(--muted);
        font-family: Aptos, 'Gill Sans', 'PingFang SC', 'Noto Sans SC', sans-serif;
        font-size: 0.78rem;
        font-weight: 400;
      }

      .navlinks {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        justify-content: flex-end;
      }

      .navlinks a,
      .button {
        border: 1px solid var(--line);
        border-radius: 7px;
        font-size: 0.88rem;
        line-height: 1;
        padding: 11px 13px;
        text-decoration: none;
      }

      .navlinks a:hover,
      .button:hover {
        background: var(--soft);
        border-color: var(--accent);
      }

      .hero {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 320px;
        gap: 42px;
        padding: 70px 0 36px;
      }

      .kicker {
        color: var(--accent);
        font-size: 0.8rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        margin: 0 0 16px;
        text-transform: uppercase;
      }

      h1 {
        font-family: Georgia, 'Times New Roman', serif;
        font-size: clamp(2.4rem, 5vw, 4.8rem);
        line-height: 0.98;
        margin: 0;
      }

      .lead {
        color: #3e4944;
        font-size: 1.08rem;
        line-height: 1.8;
        margin: 24px 0 0;
        max-width: 780px;
      }

      .source-card {
        align-self: end;
        border-left: 3px solid var(--accent);
        padding-left: 18px;
      }

      .source-card strong {
        display: block;
        font-size: 1.18rem;
        margin-bottom: 10px;
      }

      .source-card p {
        color: var(--muted);
        line-height: 1.7;
        margin: 0 0 12px;
      }

      .controls {
        align-items: center;
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 12px;
        box-shadow: var(--shadow);
        display: grid;
        gap: 12px;
        grid-template-columns: 180px minmax(0, 1fr) auto;
        padding: 14px;
      }

      label {
        color: var(--muted);
        display: grid;
        font-size: 0.78rem;
        gap: 5px;
      }

      select,
      input {
        background: #fff;
        border: 1px solid var(--line);
        border-radius: 8px;
        color: var(--ink);
        font: inherit;
        padding: 11px 12px;
      }

      .count {
        color: var(--muted);
        font-size: 0.92rem;
        white-space: nowrap;
      }

      .health {
        color: var(--muted);
        font-size: 0.92rem;
        line-height: 1.65;
        margin: 18px 0 0;
      }

      .badge {
        border: 1px solid var(--line);
        border-radius: 999px;
        display: inline-flex;
        margin: 0 6px 6px 0;
        padding: 4px 9px;
      }

      .grid {
        display: grid;
        gap: 14px;
        padding: 22px 0 70px;
      }

      .card {
        background: rgba(255, 255, 255, 0.88);
        border: 1px solid var(--line);
        border-radius: 12px;
        box-shadow: 0 12px 36px rgba(23, 33, 29, 0.06);
        padding: 20px;
      }

      .title {
        font-size: 1.08rem;
        line-height: 1.45;
        margin: 0 0 10px;
      }

      .title a {
        text-decoration-color: color-mix(in srgb, var(--accent) 45%, transparent);
        text-underline-offset: 4px;
      }

      .meta {
        color: var(--muted);
        font-size: 0.9rem;
        line-height: 1.65;
        margin: 0;
      }

      .empty {
        border: 1px dashed var(--line);
        border-radius: 12px;
        color: var(--muted);
        padding: 24px;
      }

      @media (max-width: 820px) {
        .hero,
        .controls {
          grid-template-columns: 1fr;
        }

        .source-card {
          max-width: 640px;
        }
      }
    </style>
  </head>
  <body data-conf={conf}>
    <header class="topbar">
      <nav class="shell nav" aria-label="会议论文导航">
        <a class="brand" href="/">
          Yongfang190 Eng
          <span>AI Security · Top Security Conferences</span>
        </a>
        <div class="navlinks">
          <a href="/">首页</a>
          <a href="/conf/ndss">NDSS</a>
          <a href="/conf/sp">S&P</a>
          <a href="/conf/usenix">USENIX</a>
          <a href="/conf/ccs">CCS</a>
        </div>
      </nav>
    </header>

    <main>
      <section class="shell hero">
        <div>
          <p class="kicker">Security Conference Library</p>
          <h1>{meta.title}</h1>
          <p class="lead">
            {meta.name}。这里按年度跟踪论文列表，服务于 AI 安全、网络安全、系统安全和论文思想拆解。
          </p>
        </div>
        <aside class="source-card">
          <strong>{meta.theme}</strong>
          <p>数据抓取策略：优先读取官网页面，官网结构变化或暂未发布时使用 DBLP 兜底。</p>
          <a class="button" href={meta.official} target="_blank" rel="noopener">打开官网</a>
        </aside>
      </section>

      <section class="shell">
        <div class="controls">
          <label>
            Year
            <select id="yearSel">
              {defaultYears.map((year) => <option value={year}>{year}</option>)}
            </select>
          </label>
          <label>
            Search
            <input id="qInput" placeholder="Search title / author / tag…" />
          </label>
          <span id="count" class="count"></span>
        </div>
        <div class="health" id="health">加载年度统计中...</div>
      </section>

      <section class="shell grid" id="cards" aria-live="polite"></section>
    </main>

    <script>
      const conf = document.body.dataset.conf;
      const yearSel = document.getElementById('yearSel');
      const qInput = document.getElementById('qInput');
      const cards = document.getElementById('cards');
      const countEl = document.getElementById('count');
      const health = document.getElementById('health');

      async function loadIndex() {
        try {
          const res = await fetch(`/data/${conf}/index.json?ts=${Date.now()}`);
          if (!res.ok) throw new Error('missing index');
          const summary = await res.json();
          const years = Object.entries(summary.years || {}).sort((a, b) => Number(b[0]) - Number(a[0]));
          if (years.length) {
            yearSel.innerHTML = years
              .map(([year, info]) => `<option value="${year}" data-count="${info?.count ?? 0}">${year} (${info?.count ?? 0})</option>`)
              .join('');
          }
          const badges = years
            .map(([year, info]) => `<span class="badge">${year}: ${info?.count ?? 0} · ${info?.source || 'unknown'}</span>`)
            .join('');
          const updated = summary.last_updated ? new Date(summary.last_updated).toLocaleString() : 'unknown';
          health.innerHTML = `${summary.conference || conf} · 更新：${updated}<br />${badges}`;
        } catch (error) {
          health.textContent = '暂未加载到年度索引；请检查 public/data 目录或稍后重试。';
        }
      }

      async function fetchYear(year) {
        try {
          const res = await fetch(`/data/${conf}/${year}.json?ts=${Date.now()}`);
          if (!res.ok) return { items: [] };
          return res.json();
        } catch (error) {
          return { items: [] };
        }
      }

      function escapeHtml(value) {
        return String(value || '')
          .replaceAll('&', '&amp;')
          .replaceAll('<', '&lt;')
          .replaceAll('>', '&gt;')
          .replaceAll('"', '&quot;')
          .replaceAll("'", '&#39;');
      }

      function render(items, data) {
        if (!items.length) {
          const official = data?.official_source_url || '#';
          cards.innerHTML = `
            <div class="empty">
              当前筛选没有结果。若该年份官网尚未发布论文，请访问
              <a href="${escapeHtml(official)}" target="_blank" rel="noopener">官方页面</a>
              或等待每日数据任务更新。
            </div>`;
          countEl.textContent = '0 results';
          return;
        }
        cards.innerHTML = items
          .map((paper) => {
            const authors = (paper.authors || []).join(', ');
            const href = paper.pdf_url || paper.source_url || '#';
            const source = paper.source || data?.source || '';
            return `
              <article class="card">
                <h2 class="title"><a href="${escapeHtml(href)}" target="_blank" rel="noopener">${escapeHtml(paper.title)}</a></h2>
                <p class="meta">${escapeHtml(authors || 'Authors pending')} · ${escapeHtml(paper.year || '')} · ${escapeHtml(source)}</p>
                ${paper.llm_summary_zh ? `<p>${escapeHtml(paper.llm_summary_zh)}</p>` : ''}
              </article>`;
          })
          .join('');
        countEl.textContent = `${items.length} results`;
      }

      const params = new URLSearchParams(location.search);
      let year = Number(params.get('year') || new Date().getFullYear());
      let query = (params.get('q') || '').toLowerCase();

      function syncUrl() {
        const url = new URL(location.href);
        url.searchParams.set('year', String(year));
        query ? url.searchParams.set('q', query) : url.searchParams.delete('q');
        history.replaceState(null, '', url);
      }

      async function load() {
        const data = await fetchYear(year);
        const items = (data.items || []).filter((paper) => {
          if (!query) return true;
          const haystack = [
            paper.title || '',
            ...(paper.authors || []),
            ...(paper.tags || []),
            paper.llm_summary_zh || '',
            paper.source || ''
          ].join(' ').toLowerCase();
          return haystack.includes(query);
        });
        render(items, data);
      }

      yearSel.addEventListener('change', () => {
        year = Number(yearSel.value);
        syncUrl();
        load();
      });

      qInput.addEventListener('input', () => {
        query = qInput.value.toLowerCase();
        syncUrl();
        load();
      });

      (async () => {
        await loadIndex();
        const options = [...yearSel.options];
        if (options.length) {
          const requested = options.find((option) => Number(option.value) === year);
          const firstPositive = options.find((option) => Number(option.dataset.count || 0) > 0);
          if (!requested || Number(requested.dataset.count || 0) === 0) {
            year = Number((firstPositive || options[0]).value);
          }
        }
        yearSel.value = String(year);
        qInput.value = query;
        await load();
      })();
    </script>
  </body>
</html>
